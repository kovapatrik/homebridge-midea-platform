{
  "displayName": "Homebridge Midea Platform",
  "name": "homebridge-midea-platform",
  "type": "module",
  "version": "1.3.0-beta.6",
  "description": "Homebridge plugin for Midea devices",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kovapatrik/homebridge-midea-platform.git"
  },
  "bugs": {
    "url": "https://github.com/kovapatrik/homebridge-midea/issues"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/kovapatrik"
    },
    {
      "type": "buymeacoffee",
      "url": "https://www.buymeacoffee.com/kovapatrik"
    }
  ],
  "engines": {
    "node": "^22.10.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "lint": "biome lint --error-on-warnings ./src",
    "watch": "npm run build && npm link && nodemon",
    "build": "rimraf ./dist && tsc && npm run build:ui",
    "build:ui": "rolldown -c rolldown.config.ts",
    "prepublishOnly": "npm run lint && npm run build",
    "format": "biome format ./src --write",
    "check": "biome check ./src --fix"
  },
  "keywords": [
    "homebridge-plugin"
  ],
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.2.4",
    "axios": "^1.18.1",
    "fast-xml-parser": "^5.9.3",
    "luxon": "^3.7.2",
    "semaphore-promise": "^1.4.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.6",
    "@types/lodash-es": "^4.17.12",
    "@types/luxon": "^3.7.2",
    "@types/node": "^25.9.4",
    "homebridge": "^2.1.0",
    "lodash-es": "^4.18.1",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "rolldown": "^1.1.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
